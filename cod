<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>26.02.26 | Разработчик</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Inter', Roboto, 'Helvetica Neue', sans-serif;
            background: linear-gradient(145deg, #1e293b 0%, #0f172a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 50%, rgba(37, 99, 235, 0.1), transparent 70%);
            pointer-events: none;
        }

        .bio-card {
            max-width: 480px;
            width: 100%;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            border-radius: 2.5rem;
            padding: 2rem 1.8rem;
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.2);
            animation: fadeInUp 0.6s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .avatar {
            width: 110px;
            height: 110px;
            margin: 0 auto 1.2rem;
            border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6, #a855f7);
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 12px 25px -8px rgba(59, 130, 246, 0.4);
            border: 3px solid white;
            cursor: default;
        }

        .avatar-initials {
            font-size: 3.2rem;
            font-weight: 700;
            color: white;
        }

        .name {
            text-align: center;
            font-size: 1.8rem;
            font-weight: 800;
            background: linear-gradient(120deg, #1e293b, #2d3a5e);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 0.5rem;
        }

        .bio-text {
            text-align: center;
            color: #475569;
            font-size: 0.95rem;
            margin-bottom: 1.5rem;
            line-height: 1.5;
        }

        .location {
            text-align: center;
            font-size: 0.85rem;
            color: #5b6e8c;
            margin-bottom: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .telegram-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: linear-gradient(95deg, #2aabee, #229ed9);
            padding: 1rem 1.5rem;
            border-radius: 60px;
            text-decoration: none;
            color: white;
            font-weight: 700;
            font-size: 1.2rem;
            transition: all 0.25s ease;
            margin-bottom: 1.8rem;
            box-shadow: 0 6px 14px rgba(42, 171, 238, 0.3);
            border: 1px solid rgba(255,255,255,0.3);
            cursor: pointer;
        }

        .telegram-btn i {
            font-size: 1.6rem;
        }

        .telegram-btn:hover {
            transform: translateY(-3px);
            background: linear-gradient(95deg, #229ed9, #1e88c5);
            box-shadow: 0 12px 22px rgba(42, 171, 238, 0.4);
        }

        .telegram-btn:active {
            transform: translateY(1px);
        }

        .links-grid {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .link-item {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #f1f5f9;
            padding: 0.9rem 1.2rem;
            border-radius: 50px;
            text-decoration: none;
            color: #1e293b;
            font-weight: 500;
            transition: all 0.2s;
            border: 1px solid #e2e8f0;
            cursor: pointer;
        }

        .link-item i:first-child {
            width: 24px;
            font-size: 1.2rem;
            color: #3b82f6;
        }

        .link-item span {
            flex: 1;
        }

        .link-item:hover {
            background: white;
            border-color: #3b82f6;
            transform: translateX(5px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

        .divider {
            height: 1px;
            background: #e2e8f0;
            margin: 1.5rem 0 1rem;
        }

        .footer-note {
            text-align: center;
            font-size: 0.7rem;
            color: #94a3b8;
            margin-top: 1.5rem;
            line-height: 1.4;
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>

<div class="bio-card">
    <div class="avatar">
        <div class="avatar-initials">🐍</div>
    </div>

    <h1 class="name">26.02.26</h1>
    <div class="bio-text">
        🐍 Работаю с Python и HTML/CSS | 🤖 Делаю Telegram ботов
    </div>
    <div class="location">
        <i class="fas fa-code"></i> Разработчик
    </div>

    <!-- ГЛАВНАЯ КНОПКА TELEGRAM -->
    <a href="https://t.me/j26_02_26" class="telegram-btn" target="_blank" rel="noopener noreferrer">
        <i class="fab fa-telegram-plane"></i> Написать в Telegram
    </a>

    <div class="links-grid">
        <!-- ССЫЛКА НА ПОРТФОЛИО (Telegram канал) - ИСПРАВЛЕНА -->
        <a href="https://t.me/q26_02_26" class="link-item" target="_blank" rel="noopener noreferrer">
            <i class="fas fa-folder-open"></i>
            <span>Моё портфолио / Канал</span>
            <i class="fas fa-external-link-alt" style="font-size: 0.8rem;"></i>
        </a>
        
        <!-- ДОПОЛНИТЕЛЬНАЯ ССЫЛКА НА БОТОВ (можно заменить позже) -->
        <a href="#" class="link-item" style="opacity: 0.6; cursor: default;" onclick="return false;">
            <i class="fab fa-telegram"></i>
            <span>Мои Telegram боты (скоро)</span>
            <i class="fas fa-clock" style="font-size: 0.8rem;"></i>
        </a>
    </div>

    <div class="divider"></div>
    <div class="footer-note">
        ⚡ Python • HTML/CSS • Telegram Bot API<br>
        📩 Быстрая связь — отвечаю в течение дня
    </div>
</div>

<script>
    // Проверка ссылок при загрузке страницы
    console.log("✅ Сайт загружен!");
    console.log("📱 Telegram для связи: https://t.me/j26_02_26");
    console.log("📁 Портфолио/канал: https://t.me/q26_02_26");
    
    // Дополнительная проверка: если ссылка не открывается, показать подсказку
    const portfolioLink = document.querySelector('.link-item[href="https://t.me/q26_02_26"]');
    if (portfolioLink) {
        portfolioLink.addEventListener('click', function(e) {
            console.log("🔗 Открывается портфолио: https://t.me/q26_02_26");
            // Ссылка откроется в новой вкладке благодаря target="_blank"
        });
    }
</script>

</body>
</html>